# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if having platform-specific dependencies or if
#   dependencies are not stabilized yet, associating pipfile.lock with git might cause issues.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the resolved dependencies and should
#   be checked-in if building an executable/app, but not for a library.
#poetry.lock

# pdm
#   Similar to Poetry and Pipfile, pdm.lock contains resolved dependency versions
#pdm.lock
#   pdm local configuration
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

